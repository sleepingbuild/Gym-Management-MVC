@{
    ViewData["Title"] = "Model Evaluation Charts";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <h1 class="text-center mb-4">📊 Model Evaluation Results</h1>

    <!-- Biểu đồ 1: Training Loss - Full width -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="card-title mb-0">📈 Training Loss Curve</h4>
                </div>
                <div class="card-body text-center">
                    <img src="~/images/charts/training_loss_curve.png"
                         alt="Training Loss Curve"
                         class="img-fluid"
                         style="max-width: 100%; height: auto;" />
                    <div class="mt-3">
                        <span class="badge bg-success">Initial: 2.35</span>
                        <span class="badge bg-info">Final: 0.59</span>
                        <span class="badge bg-warning">↓ 75%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Biểu đồ 2: Bar Chart - Full width -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="card-title mb-0">📊 Manual Evaluation - 10 Questions</h4>
                </div>
                <div class="card-body text-center">
                    <img src="~/images/charts/manual_evaluation_bars.png"
                         alt="Manual Evaluation"
                         class="img-fluid"
                         style="max-width: 100%; height: auto;" />
                    <div class="mt-3">
                        <span class="badge bg-primary">Relevance: 4.7</span>
                        <span class="badge bg-danger">Accuracy: 4.6</span>
                        <span class="badge bg-warning">Fluency: 4.6</span>
                        <span class="badge bg-success">Overall: 4.63</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Biểu đồ 3: Radar Chart - Căn giữa, chiếm 50% màn hình -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="card-title mb-0">🎯 Performance Radar</h4>
                </div>
                <div class="card-body text-center">
                    <img src="~/images/charts/manual_evaluation_radar.png"
                         alt="Radar Chart"
                         class="img-fluid"
                         style="max-width: 500px; height: auto;" />
                    <div class="mt-3">
                        <p class="text-muted">Model đạt điểm cao ở cả 3 tiêu chí</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>