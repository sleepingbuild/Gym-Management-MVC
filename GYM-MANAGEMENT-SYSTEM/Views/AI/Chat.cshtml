@model GYM_MANAGEMENT_SYSTEM.ViewModels.ChatViewModel

@{
    ViewData["Title"] = "AI Fitness Trainer";
}

<style>
    /* ── Tokens ── */
    :root {
        --gym-dark: #0f1117;
        --gym-card: #1a1d27;
        --gym-border: #2a2d3a;
        --gym-accent: #f97316;
        --gym-accent2: #fb923c;
        --gym-text: #e2e8f0;
        --gym-muted: #64748b;
        --gym-user-bg: #1e3a5f;
        --gym-bot-bg: #1a1d27;
        --gym-input: #12151e;
        --radius: 14px;
    }

    body {
        background: var(--gym-dark);
        color: var(--gym-text);
    }

    /* ── Layout ── */
    .chat-wrapper {
        max-width: 820px;
        margin: 0 auto;
        padding: 2rem 1rem 6rem;
        font-family: 'Inter', system-ui, sans-serif;
    }

    /* ── Header ── */
    .chat-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 2rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid var(--gym-border);
    }

        .chat-header .avatar {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, var(--gym-accent), #ef4444);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            flex-shrink: 0;
            box-shadow: 0 0 20px rgba(249,115,22,.35);
        }

        .chat-header h1 {
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0;
            letter-spacing: -.01em;
        }

        .chat-header p {
            font-size: .8rem;
            color: var(--gym-muted);
            margin: 2px 0 0;
        }

    .status-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        background: #22c55e;
        border-radius: 50%;
        margin-right: 5px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: .4;
        }
    }

    /* ── History ── */
    .chat-history {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        margin-bottom: 1.5rem;
        min-height: 120px;
    }

    /* User bubble */
    .msg-user {
        display: flex;
        justify-content: flex-end;
    }

        .msg-user .bubble {
            background: linear-gradient(135deg, var(--gym-accent), var(--gym-accent2));
            color: #fff;
            padding: .75rem 1.1rem;
            border-radius: var(--radius) var(--radius) 4px var(--radius);
            max-width: 72%;
            font-size: .9rem;
            line-height: 1.55;
            box-shadow: 0 4px 16px rgba(249,115,22,.2);
        }

    /* Bot bubble */
    .msg-bot {
        display: flex;
        gap: 10px;
        align-items: flex-start;
    }

        .msg-bot .bot-icon {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg,#7c3aed,#ef4444);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .msg-bot .bubble {
            background: var(--gym-bot-bg);
            border: 1px solid var(--gym-border);
            padding: .75rem 1.1rem;
            border-radius: var(--radius) var(--radius) var(--radius) 4px;
            max-width: 72%;
            font-size: .9rem;
            line-height: 1.6;
            color: var(--gym-text);
        }

    .msg-time {
        font-size: .7rem;
        color: var(--gym-muted);
        margin-top: 4px;
        text-align: right;
    }

    .msg-bot .msg-time {
        text-align: left;
        padding-left: 42px;
    }

    /* ── Empty state ── */
    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--gym-muted);
    }

        .empty-state .icon {
            font-size: 3rem;
            margin-bottom: .75rem;
        }

        .empty-state p {
            font-size: .9rem;
        }

    .suggestion-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
        margin-top: 1rem;
    }

    .chip {
        background: var(--gym-card);
        border: 1px solid var(--gym-border);
        color: var(--gym-text);
        padding: .4rem .9rem;
        border-radius: 999px;
        font-size: .78rem;
        cursor: pointer;
        transition: border-color .2s, color .2s;
        text-decoration: none;
    }

        .chip:hover {
            border-color: var(--gym-accent);
            color: var(--gym-accent);
        }

    /* ── New answer highlight ── */
    .msg-new .bubble {
        animation: fadeSlide .4s ease;
    }

    @@keyframes fadeSlide {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ── Input bar (sticky bottom) ── */
    .input-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(15,17,23,.92);
        backdrop-filter: blur(12px);
        border-top: 1px solid var(--gym-border);
        padding: 1rem;
        z-index: 100;
    }

    .input-inner {
        max-width: 820px;
        margin: 0 auto;
        display: flex;
        gap: 10px;
        align-items: center;
    }

        .input-inner input[type=text] {
            flex: 1;
            background: var(--gym-input);
            border: 1px solid var(--gym-border);
            color: var(--gym-text);
            border-radius: 999px;
            padding: .7rem 1.25rem;
            font-size: .9rem;
            outline: none;
            transition: border-color .2s;
        }

            .input-inner input[type=text]:focus {
                border-color: var(--gym-accent);
            }

            .input-inner input[type=text]::placeholder {
                color: var(--gym-muted);
            }

    .send-btn {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, var(--gym-accent), var(--gym-accent2));
        border: none;
        border-radius: 50%;
        color: #fff;
        font-size: 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: transform .15s, box-shadow .15s;
        box-shadow: 0 4px 12px rgba(249,115,22,.3);
    }

        .send-btn:hover {
            transform: scale(1.08);
        }

        .send-btn:active {
            transform: scale(.96);
        }
</style>

<div class="chat-wrapper">

    <!-- Header -->
    <div class="chat-header">
        <div class="avatar">🏋️</div>
        <div>
            <h1>AI Fitness Trainer</h1>
            <p><span class="status-dot"></span>Sẵn sàng tư vấn</p>
        </div>
    </div>

    <!-- Chat history -->
    <div class="chat-history" id="chatHistory">

        @if (!Model.Histories.Any() && string.IsNullOrEmpty(Model.Answer))
        {
            <div class="empty-state">
                <div class="icon">💪</div>
                <p>Chào bạn! Hãy hỏi tôi bất cứ điều gì về<br />tập luyện, dinh dưỡng và sức khoẻ.</p>
                <div class="suggestion-chips">
                    <a class="chip" onclick="fillQuestion(this)">Tập gym mấy ngày/tuần?</a>
                    <a class="chip" onclick="fillQuestion(this)">Whey protein có cần thiết không?</a>
                    <a class="chip" onclick="fillQuestion(this)">Cách giảm mỡ bụng hiệu quả?</a>
                    <a class="chip" onclick="fillQuestion(this)">Squat đúng kỹ thuật như thế nào?</a>
                </div>
            </div>
        }

        @foreach (var item in Model.Histories.OrderBy(x => x.CreatedAt))
        {
            <!-- User -->
            <div class="msg-user">
                <div>
                    <div class="bubble">@item.Question</div>
                    <div class="msg-time">@item.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                </div>
            </div>
            <!-- Bot -->
            <div class="msg-bot">
                <div class="bot-icon">🤖</div>
                <div>
                    <div class="bubble">@item.Answer</div>
                    <div class="msg-time">@item.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Answer) &&
             !Model.Histories.Any(h => h.Answer == Model.Answer))
        {
            <div class="msg-user">
                <div>
                    <div class="bubble">@Model.Question</div>
                </div>
            </div>
            <div class="msg-bot msg-new">
                <div class="bot-icon">🤖</div>
                <div>
                    <div class="bubble">@Model.Answer</div>
                </div>
            </div>
        }

    </div>
</div>

<!-- Sticky input bar -->
<div class="input-bar">
    <form method="post" class="input-inner" id="chatForm">
        @Html.AntiForgeryToken()
        <input asp-for="Question"
               id="questionInput"
               type="text"
               placeholder="Hỏi về workout, dinh dưỡng, lịch tập..."
               autocomplete="off" />
        <button type="submit" class="send-btn" title="Gửi">➤</button>
    </form>
</div>

<script>
    // Auto scroll to bottom
    window.addEventListener('load', () => {
        const h = document.getElementById('chatHistory');
        h.scrollTop = h.scrollHeight;
    });

    // Fill suggestion chips into input
    function fillQuestion(el) {
        document.getElementById('questionInput').value = el.textContent.trim();
        document.getElementById('questionInput').focus();
    }

    // Disable send button while waiting
    document.getElementById('chatForm').addEventListener('submit', function () {
        const btn = this.querySelector('.send-btn');
        btn.innerHTML = '⏳';
        btn.disabled = true;
    });
</script>
