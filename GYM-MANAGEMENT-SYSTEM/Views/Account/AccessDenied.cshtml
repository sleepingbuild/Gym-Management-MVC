@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card-fitness">
                <div class="card-header" style="background: var(--error-gradient);">
                    <i class="fas fa-exclamation-triangle"></i>
                    Truy cập bị từ chối
                </div>
                <div class="card-body py-5">
                    <i class="fas fa-lock" style="font-size: 4rem; color: var(--error-red); margin-bottom: 1.5rem;"></i>
                    <h4 class="text-white">Bạn không có quyền truy cập</h4>
                    <p class="text-muted">
                        Trang này yêu cầu quyền truy cập đặc biệt. Vui lòng liên hệ với quản trị viên nếu bạn cần hỗ trợ.
                    </p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-fitness-primary mt-3">
                        <i class="fas fa-home me-2"></i>Về trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>