@model GYM_MANAGEMENT_SYSTEM.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8 col-11">
                <div class="auth-card">
                    <!-- Header -->
                    <div class="auth-header">
                        <div class="auth-icon">
                            <i class="fas fa-user-plus"></i>
                        </div>
                        <h3>Bắt đầu hành trình</h3>
                        <p>Đăng ký để trở thành thành viên</p>
                    </div>

                    <!-- Body -->
                    <div class="auth-body">
                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="row">
                                <div class="col-12 mb-3">
                                    <label asp-for="FullName" class="form-label">
                                        <i class="fas fa-user me-2"></i>Họ và tên
                                    </label>
                                    <input asp-for="FullName" class="form-control"
                                           placeholder="Nguyễn Văn A" />
                                    <span asp-validation-for="FullName" class="text-danger small"></span>
                                </div>

                                <div class="col-12 mb-3">
                                    <label asp-for="Email" class="form-label">
                                        <i class="fas fa-envelope me-2"></i>Email
                                    </label>
                                    <input asp-for="Email" class="form-control"
                                           placeholder="example@email.com" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="col-12 mb-3">
                                    <label asp-for="PhoneNumber" class="form-label">
                                        <i class="fas fa-phone me-2"></i>Số điện thoại
                                    </label>
                                    <input asp-for="PhoneNumber" class="form-control"
                                           placeholder="0987654321" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>

                                <div class="col-12 mb-3">
                                    <label asp-for="Password" class="form-label">
                                        <i class="fas fa-lock me-2"></i>Mật khẩu
                                    </label>
                                    <input asp-for="Password" class="form-control"
                                           placeholder="••••••••" />
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="col-12 mb-4">
                                    <label asp-for="ConfirmPassword" class="form-label">
                                        <i class="fas fa-check-circle me-2"></i>Xác nhận mật khẩu
                                    </label>
                                    <input asp-for="ConfirmPassword" class="form-control"
                                           placeholder="••••••••" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-fitness-primary w-100">
                                <i class="fas fa-user-plus me-2"></i>Tạo tài khoản
                            </button>
                        </form>
                    </div>

                    <!-- Footer -->
                    <div class="auth-footer">
                        <p class="mb-0">
                            Đã có tài khoản?
                            <a asp-action="Login">Đăng nhập ngay</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}