<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gym Management</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Fitness Style -->
    <link rel="stylesheet" href="~/css/fitness-style.css" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- ===== NAVBAR ===== -->
    <nav class="navbar navbar-expand-lg navbar-fitness sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-dumbbell"></i>GYM<span>SYSTEM</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarFitness">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarFitness">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Trang chủ
                        </a>
                    </li>
                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin") || User.IsInRole("Trainer"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-cog me-1"></i>Quản lý
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Package" asp-action="Index">
                                            <i class="fas fa-box me-2"></i>Gói tập
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Trainer" asp-action="Index">
                                            <i class="fas fa-user-tie me-2"></i>Huấn luyện viên
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">
                                                <i class="fas fa-chart-pie me-2"></i>Dashboard
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AI" ? "active" : "")"
                               asp-controller="AI" asp-action="Chat">
                                <i class="fas fa-robot me-1"></i>Trợ lý AI
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i>@User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                        <i class="fas fa-id-card me-2"></i>Thông tin
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Memberships">
                                        <i class="fas fa-ticket-alt me-2"></i>Thẻ tập
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn-fitness-primary" asp-controller="Account" asp-action="Register"
                               style="padding: 0.5rem 1.5rem !important; border-radius: 50px;">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- ===== MAIN CONTENT ===== -->
    <main role="main" class="pb-5">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="footer-fitness">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <div class="footer-brand">
                        <i class="fas fa-dumbbell" style="color: var(--orange-primary);"></i>GYM<span>SYSTEM</span>
                    </div>
                    <p class="footer-text mt-3">
                        Hệ thống quản lý phòng gym hiện đại, tích hợp AI và công nghệ mới nhất.
                    </p>
                    <div class="mt-3">
                        <a href="#" class="text-white me-3" style="opacity: 0.6; transition: opacity 0.3s;">
                            <i class="fab fa-facebook fa-lg"></i>
                        </a>
                        <a href="#" class="text-white me-3" style="opacity: 0.6; transition: opacity 0.3s;">
                            <i class="fab fa-instagram fa-lg"></i>
                        </a>
                        <a href="#" class="text-white me-3" style="opacity: 0.6; transition: opacity 0.3s;">
                            <i class="fab fa-youtube fa-lg"></i>
                        </a>
                        <a href="#" class="text-white" style="opacity: 0.6; transition: opacity 0.3s;">
                            <i class="fab fa-tiktok fa-lg"></i>
                        </a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4 mb-4 mb-md-0">
                    <h6 class="text-white fw-bold mb-3">Menu</h6>
                    <div class="footer-links">
                        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                        <a asp-controller="AI" asp-action="Chat">Trợ lý AI</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        }
                    </div>
                </div>
                <div class="col-lg-2 col-md-4 mb-4 mb-md-0">
                    <h6 class="text-white fw-bold mb-3">Hỗ trợ</h6>
                    <div class="footer-links">
                        <a href="#">FAQ</a>
                        <a href="#">Liên hệ</a>
                        <a href="#">Hướng dẫn</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h6 class="text-white fw-bold mb-3">Liên hệ</h6>
                    <p class="footer-text">
                        <i class="fas fa-map-marker-alt me-2" style="color: var(--orange-primary);"></i>
                        123 Đường ABC, Quận 1, TP.HCM
                    </p>
                    <p class="footer-text">
                        <i class="fas fa-envelope me-2" style="color: var(--orange-primary);"></i>
                        contact@gymsystem.com
                    </p>
                    <p class="footer-text">
                        <i class="fas fa-phone me-2" style="color: var(--orange-primary);"></i>
                        (028) 1234 5678
                    </p>
                </div>
            </div>
            <div class="footer-bottom text-center">
                <p class="mb-0">
                    &copy; @DateTime.Now.Year Gym Management System. All rights reserved.
                    <br class="d-md-none" />
                    <span class="text-muted">Made with <i class="fas fa-heart" style="color: var(--orange-primary);"></i> by Team Gym</span>
                </p>
            </div>
        </div>
    </footer>

    <!-- ===== SCRIPTS ===== -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>